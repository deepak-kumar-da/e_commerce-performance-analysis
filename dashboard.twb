    <worksheet name='Freight Cost'>
      <table>
        <view>
          <datasources>
            <datasource caption='Orders' name='federated.04gzaul0whs8x515y13101qvg6en' />
          </datasources>
          <datasource-dependencies datasource='federated.04gzaul0whs8x515y13101qvg6en'>
            <column caption='Volumetric Weight' datatype='real' name='[Calculation_1390074256158728]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='([Product_Length] * [Product_Height] * [Product_Width]) / 5000' />
            </column>
            <column caption='Transportation' datatype='string' name='[Calculation_1390074257006602]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_1390074259636235] &lt;=2 THEN &apos;Light &amp; Compact&apos;&#13;&#10;ELSEIF  [Calculation_1390074259636235] &lt;=12 THEN &apos;Standard&apos;&#13;&#10;ELSEIF  [Calculation_1390074259636235] &lt;=30 THEN &apos;Heavy&apos;&#13;&#10;ELSEIF  [Calculation_1390074259636235] &gt; 30 THEN &apos;Cargo&apos;&#13;&#10;ELSE &apos;&apos;&#13;&#10;END' />
            </column>
            <column caption='Chargable Weight' datatype='real' name='[Calculation_1390074259636235]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='if [Calculation_1390074256158728] &gt; [Calculation_1390074264137740] THEN [Calculation_1390074256158728]&#13;&#10;ELSE [Calculation_1390074264137740]&#13;&#10;END' />
            </column>
            <column caption='Product weight in kg' datatype='real' name='[Calculation_1390074264137740]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[Product_Weight] / 1000' />
            </column>
            <column caption='Product Height' datatype='integer' name='[Product_Height]' role='measure' type='quantitative' />
            <column caption='Product Length' datatype='integer' name='[Product_Length]' role='measure' type='quantitative' />
            <column caption='Product Weight' datatype='integer' name='[Product_Weight]' role='measure' type='quantitative' />
            <column caption='Product Width' datatype='integer' name='[Product_Width]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_1390074257006602]' derivation='None' name='[none:Calculation_1390074257006602:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_1390074256158728]' derivation='Sum' name='[sum:Calculation_1390074256158728:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_1390074264137740]' derivation='Sum' name='[sum:Calculation_1390074264137740:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <filter class='quantitative' column='[federated.04gzaul0whs8x515y13101qvg6en].[sum:Calculation_1390074256158728:qk]' included-values='non-null' />
